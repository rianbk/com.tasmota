{
  "extends": "athom/homey-app",
  "parserOptions": {
    "project": "./tsconfig.eslint.json"
  },
  "rules": {
    "import/extensions": "off",
    "import/no-unresolved": "off",
    "node/no-missing-import": "off"
  },
  "overrides": [
    {
      "files": ["test/**/*.ts", "vitest.config.ts"],
      "rules": {
        "node/no-unpublished-import": "off"
      }
    }
  ]
}

{
  "name": {
    "en": "Tasmota Light"
  },
  "class": "light",
  "connectivity": ["lan"],
  "capabilities": [
    "onoff",
    "dim",
    "light_temperature",
    "light_hue",
    "light_saturation",
    "light_mode",
    "measure_signal_strength",
    "measure_wifi_percent"
  ],
  "capabilitiesOptions": {
    "measure_signal_strength": {
      "title": {
        "en": "WiFi Signal"
      }
    },
    "measure_wifi_percent": {
      "title": {
        "en": "WiFi Quality"
      }
    }
  },
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Behavior"
      },
      "children": [
        {
          "id": "power_on_state",
          "type": "dropdown",
          "label": {
            "en": "Power-on state"
          },
          "value": "3",
          "values": [
            { "id": "0", "label": { "en": "Off" } },
            { "id": "1", "label": { "en": "On" } },
            { "id": "2", "label": { "en": "Toggle" } },
            { "id": "3", "label": { "en": "Last state" } }
          ]
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Transitions"
      },
      "children": [
        {
          "id": "fade",
          "type": "checkbox",
          "label": {
            "en": "Fade"
          },
          "value": false
        },
        {
          "id": "speed",
          "type": "number",
          "label": {
            "en": "Speed"
          },
          "value": 4,
          "min": 1,
          "max": 40
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Device info"
      },
      "children": [
        {
          "id": "mac",
          "type": "label",
          "label": {
            "en": "MAC address"
          },
          "value": ""
        },
        {
          "id": "ip",
          "type": "label",
          "label": {
            "en": "IP address"
          },
          "value": ""
        },
        {
          "id": "model",
          "type": "label",
          "label": {
            "en": "Model"
          },
          "value": ""
        },
        {
          "id": "firmware",
          "type": "label",
          "label": {
            "en": "Firmware"
          },
          "value": ""
        }
      ]
    }
  ],
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "energy": {
    "approximation": {
      "usageOn": 9,
      "usageOff": 0.5
    }
  },
  "images": {
    "small": "/drivers/tasmota_light/assets/small.png",
    "large": "/drivers/tasmota_light/assets/large.png",
    "xlarge": "/drivers/tasmota_light/assets/xlarge.png"
  }
}
